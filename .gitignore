# *.xcodeproj/

# Derived data + build artifacts
build/
DerivedData/
*.ipa
*.dSYM.zip
*.dSYM

# Swift Package Manager
.swiftpm/
Package.resolved

# Carthage / CocoaPods (not used here, but commonly listed)
Pods/
Carthage/Build/
